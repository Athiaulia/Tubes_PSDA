    QPushButton { border-radius: 6px; color: white; font-weight: bold; font-size: 12px; height: 40px; text-transform: uppercase; }
    QTableWidget { background-color: #161630; color: white; border: none; border-radius: 12px; gridline-color: #2d2d5a; }
    QHeaderView::section { background-color: #1e1e3f; color: #7070db; font-weight: bold; border: none; padding: 6px; }
   </string>
